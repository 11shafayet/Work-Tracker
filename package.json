{
  "name": "worktracker",
  "version": "0.1.0",
  "description": "Local desktop work tracking app built with Electron, React, and SQLite.",
  "main": "src/main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && WORKTRACKER_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "start": "electron --no-sandbox .",
    "detect:active-window": "electron --no-sandbox scripts/detect-active-window.cjs",
    "detect:idle": "electron --no-sandbox scripts/detect-idle.cjs",
    "desktop:install": "bash scripts/install-linux-desktop.sh",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "better-sqlite3": "^11.10.0",
    "electron": "^35.5.1",
    "get-windows": "^9.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "concurrently": "^9.2.0",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
